      <skos:prefLabel xml:lang="mt">normali</skos:prefLabel>
      <skos:prefLabel xml:lang="hu">normál</skos:prefLabel>
      <skos:prefLabel xml:lang="sk">normálne</skos:prefLabel>
      <skos:definition xml:lang="en">Publicly accessible. This concept has been used in the schemas of IMMC, the Interinstitutional Metadata Maintenance Committee, as the predecessor of the current concept ‘public’.</skos:definition>
      <dc:identifier>NORMAL</dc:identifier>
      <atold:op-code>NORMAL</atold:op-code>
