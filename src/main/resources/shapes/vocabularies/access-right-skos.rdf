   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/access-right/CONFIDENTIAL"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/access-right"/>
      <skos:prefLabel xml:lang="it">riservato</skos:prefLabel>
      <skos:prefLabel xml:lang="sv">konfidentiellt</skos:prefLabel>
      <skos:prefLabel xml:lang="hu">bizalmas</skos:prefLabel>
      <skos:prefLabel xml:lang="bg">поверителен</skos:prefLabel>
      <skos:prefLabel xml:lang="sk">dôverné</skos:prefLabel>
      <skos:prefLabel xml:lang="cs">důvěrné</skos:prefLabel>
      <skos:prefLabel xml:lang="lv">konfidenciāls</skos:prefLabel>
      <skos:prefLabel xml:lang="sl">zaupno</skos:prefLabel>
      <skos:prefLabel xml:lang="hr">povjerljivo</skos:prefLabel>
      <skos:prefLabel xml:lang="ro">confidențial</skos:prefLabel>
      <skos:prefLabel xml:lang="es">confidencial</skos:prefLabel>
      <skos:prefLabel xml:lang="pt">confidencial</skos:prefLabel>
      <skos:prefLabel xml:lang="fi">luottamuksellinen</skos:prefLabel>
      <skos:prefLabel xml:lang="de">vertraulich</skos:prefLabel>
      <skos:prefLabel xml:lang="et">konfidentsiaalne</skos:prefLabel>
      <skos:prefLabel xml:lang="ga">rúnda</skos:prefLabel>
      <skos:prefLabel xml:lang="nl">vertrouwelijk</skos:prefLabel>
      <skos:prefLabel xml:lang="fr">confidentiel</skos:prefLabel>
      <skos:prefLabel xml:lang="en">confidential</skos:prefLabel>
      <skos:prefLabel xml:lang="pl">poufny</skos:prefLabel>
      <skos:prefLabel xml:lang="lt">konfidencialus</skos:prefLabel>
      <skos:prefLabel xml:lang="mt">kunfidenzjali</skos:prefLabel>
      <skos:prefLabel xml:lang="el">εμπιστευτικό</skos:prefLabel>
      <skos:prefLabel xml:lang="da">fortrolig</skos:prefLabel>
      <skos:definition xml:lang="en">access status for resources containing undisclosed information, the disclosure of which could cause damage to interested parties, such as public administrations and businesses</skos:definition>
      <skos:scopeNote xml:lang="en">Confidential resources may contain personal data, but this is not a defining criterion. Information on the presence of personal data should be provided separately. This may refer to personal or professional information, or to information relating to business, commerce or trade.</skos:scopeNote>
      <dc:identifier>CONFIDENTIAL</dc:identifier>
      <atold:op-code>CONFIDENTIAL</atold:op-code>
      <at:op-code>CONFIDENTIAL</at:op-code>
      <at:start.use>2021-03-17</at:start.use>
      <at:authority-code>CONFIDENTIAL</at:authority-code>
      <skos:broader rdf:resource="http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC"/>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/access-right/RESTRICTED"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/access-right"/>
      <skos:prefLabel xml:lang="nb">betinget tilgang</skos:prefLabel>
      <skos:prefLabel xml:lang="es">restringido</skos:prefLabel>
      <skos:prefLabel xml:lang="nn">tilgang på visse vilkår</skos:prefLabel>
      <skos:prefLabel xml:lang="lt">taikomi ribojimai</skos:prefLabel>
      <skos:prefLabel xml:lang="de">eingeschränkt</skos:prefLabel>
      <skos:prefLabel xml:lang="pt">restrito</skos:prefLabel>
      <skos:prefLabel xml:lang="fr">restreint</skos:prefLabel>
      <skos:prefLabel xml:lang="fi">rajoitettu</skos:prefLabel>
      <skos:prefLabel xml:lang="el">περιορισμένης χρήσης</skos:prefLabel>
      <skos:prefLabel xml:lang="cs">vyhrazeno</skos:prefLabel>
      <skos:prefLabel xml:lang="ga">teoranta</skos:prefLabel>
      <skos:prefLabel xml:lang="nl">beperkt</skos:prefLabel>
      <skos:prefLabel xml:lang="et">piiratud</skos:prefLabel>
      <skos:prefLabel xml:lang="da">begrænset</skos:prefLabel>
      <skos:prefLabel xml:lang="bg">с ограничен достъп</skos:prefLabel>
      <skos:prefLabel xml:lang="en">restricted</skos:prefLabel>
      <skos:prefLabel xml:lang="hu">korlátozott terjesztésű</skos:prefLabel>
      <skos:prefLabel xml:lang="sl">interno</skos:prefLabel>
      <skos:prefLabel xml:lang="sv">begränsad åtkomst</skos:prefLabel>
      <skos:prefLabel xml:lang="lv">ierobežotas pieejamības</skos:prefLabel>
      <skos:prefLabel xml:lang="ro">cu acces restricționat</skos:prefLabel>
      <skos:prefLabel xml:lang="it">limitato</skos:prefLabel>
      <skos:prefLabel xml:lang="hr">ograničen pristup</skos:prefLabel>
      <skos:prefLabel xml:lang="mt">ristrett</skos:prefLabel>
      <skos:prefLabel xml:lang="sk">vyhradené</skos:prefLabel>
      <skos:prefLabel xml:lang="no">betinget tilgang</skos:prefLabel>
      <skos:prefLabel xml:lang="pl">zastrzeżony</skos:prefLabel>
      <skos:definition xml:lang="en">access status for resources that are available only under certain conditions</skos:definition>
      <skos:scopeNote xml:lang="en">Restricted resources may contain personal data, but this is not a defining criterion. Information on the presence of personal data should be provided separately. This category may include resources that require payment, resources shared under non-disclosure agreements, and resources for which the publisher or owner has not yet decided whether they can be publicly released.</skos:scopeNote>
      <dc:identifier>RESTRICTED</dc:identifier>
      <atold:op-code>RESTRICTED</atold:op-code>
      <at:op-code>RESTRICTED</at:op-code>
      <at:start.use>2013-01-01</at:start.use>
      <at:authority-code>RESTRICTED</at:authority-code>
      <skos:broader rdf:resource="http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC"/>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/access-right/SENSITIVE"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/access-right"/>
      <skos:prefLabel xml:lang="el">ευαίσθητο</skos:prefLabel>
      <skos:prefLabel xml:lang="pt">sensível</skos:prefLabel>
      <skos:prefLabel xml:lang="de">sensibel</skos:prefLabel>
      <skos:prefLabel xml:lang="sl">občutljivo</skos:prefLabel>
      <skos:prefLabel xml:lang="sv">känsligt</skos:prefLabel>
      <skos:prefLabel xml:lang="mt">sensittiv</skos:prefLabel>
      <skos:prefLabel xml:lang="ro">sensibil</skos:prefLabel>
      <skos:prefLabel xml:lang="lv">sensitīvs</skos:prefLabel>
      <skos:prefLabel xml:lang="pl">sensytywny</skos:prefLabel>
      <skos:prefLabel xml:lang="lt">neskelbtinas</skos:prefLabel>
      <skos:prefLabel xml:lang="fi">arkaluonteinen</skos:prefLabel>
      <skos:prefLabel xml:lang="ga">íogair</skos:prefLabel>
      <skos:prefLabel xml:lang="da">følsom</skos:prefLabel>
      <skos:prefLabel xml:lang="et">tundlik</skos:prefLabel>
      <skos:prefLabel xml:lang="cs">citlivé</skos:prefLabel>
      <skos:prefLabel xml:lang="en">sensitive</skos:prefLabel>
      <skos:prefLabel xml:lang="sk">citlivé</skos:prefLabel>
      <skos:prefLabel xml:lang="bg">чувствителен</skos:prefLabel>
      <skos:prefLabel xml:lang="hr">osjetljivo</skos:prefLabel>
      <skos:prefLabel xml:lang="it">sensibile</skos:prefLabel>
      <skos:prefLabel xml:lang="es">sensible</skos:prefLabel>
      <skos:prefLabel xml:lang="fr">sensible</skos:prefLabel>
      <skos:prefLabel xml:lang="nl">gevoelig</skos:prefLabel>
      <skos:prefLabel xml:lang="hu">érzékeny</skos:prefLabel>
      <skos:definition xml:lang="en">statut d'accès aux ressources contenant des informations sensibles non classifiées (SNC), c'est-à-dire des informations dont la divulgation non autorisée pourrait porter préjudice à la Commission ou à d'autres parties concernées, telles que des entreprises, des sociétés, la propriété intellectuelle ou des données à caractère personnel, mais qui ne constituent pas des informations classifiées de l'UE</skos:definition>
      <skos:definition xml:lang="en">access status for resources containing sensitive non-classified (SNC) information, that is, information whose unauthorised disclosure could cause damage to the Commission or other interested parties, such as businesses, companies, intellectual property, or personal data, but which is not EU classified information</skos:definition>
      <skos:scopeNote xml:lang="en">Sensitive non-classified resources may contain personal data, but this is not a defining criterion. Information on the presence of personal data should be provided separately. This category covers information that requires protection even though it is not subject to formal EU security classification.</skos:scopeNote>
      <dc:identifier>SENSITIVE</dc:identifier>
      <atold:op-code>SENSITIVE</atold:op-code>
      <at:op-code>SENSITIVE</at:op-code>
      <at:start.use>2020-03-18</at:start.use>
      <at:authority-code>SENSITIVE</at:authority-code>
      <skos:broader rdf:resource="http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC"/>
   </skos:Concept>
</rdf:RDF>
