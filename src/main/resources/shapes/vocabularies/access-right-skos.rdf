         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xml:base="http://publications.europa.eu/resource/authority/access-right">
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/access-right/PUBLIC"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/access-right"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/access-right"/>
      <skos:prefLabel xml:lang="fi">julkinen</skos:prefLabel>
      <skos:prefLabel xml:lang="et">avalik</skos:prefLabel>
      <skos:prefLabel xml:lang="lt">viešas</skos:prefLabel>
      <skos:prefLabel xml:lang="sv">offentligt</skos:prefLabel>
      <skos:prefLabel xml:lang="lv">publiski pieejams</skos:prefLabel>
      <skos:prefLabel xml:lang="mt">pubbliku</skos:prefLabel>
      <skos:prefLabel xml:lang="en">public</skos:prefLabel>
      <skos:prefLabel xml:lang="fr">public</skos:prefLabel>
      <skos:prefLabel xml:lang="ro">public</skos:prefLabel>
      <skos:prefLabel xml:lang="el">δημόσιο</skos:prefLabel>
      <skos:prefLabel xml:lang="pt">público</skos:prefLabel>
      <skos:prefLabel xml:lang="es">público</skos:prefLabel>
      <skos:prefLabel xml:lang="it">pubblico</skos:prefLabel>
      <skos:prefLabel xml:lang="sk">verejné</skos:prefLabel>
      <skos:prefLabel xml:lang="sl">javno</skos:prefLabel>
      <skos:prefLabel xml:lang="bg">публичен</skos:prefLabel>
      <skos:prefLabel xml:lang="nl">openbaar</skos:prefLabel>
      <skos:prefLabel xml:lang="nn">allmenn tilgang</skos:prefLabel>
      <skos:prefLabel xml:lang="pl">publiczny</skos:prefLabel>
      <skos:prefLabel xml:lang="de">öffentlich</skos:prefLabel>
      <skos:prefLabel xml:lang="hu">nyilvános</skos:prefLabel>
      <skos:prefLabel xml:lang="nb">allmenn tilgang</skos:prefLabel>
      <skos:prefLabel xml:lang="ga">poiblí</skos:prefLabel>
      <skos:prefLabel xml:lang="da">offentlig</skos:prefLabel>
      <skos:prefLabel xml:lang="no">allmenn tilgang</skos:prefLabel>
      <skos:prefLabel xml:lang="cs">veřejné</skos:prefLabel>
      <skos:prefLabel xml:lang="hr">za javnu objavu</skos:prefLabel>
      <skos:definition xml:lang="en">access status for resources that are publicly accessible</skos:definition>
      <skos:scopeNote xml:lang="en">The presence or absence of personal data is not a defining criterion for this concept. Information on the presence of personal data should be provided separately. Requirements such as registration or requests for API keys are compatible with this concept, provided that anyone can request such registration or API keys.</skos:scopeNote>
      <dc:identifier>PUBLIC</dc:identifier>
      <atold:op-code>PUBLIC</atold:op-code>
      <at:op-code>PUBLIC</at:op-code>
      <at:start.use>2013-01-01</at:start.use>
      <at:authority-code>PUBLIC</at:authority-code>
   </skos:Concept>
   <skos:ConceptScheme rdf:about="http://publications.europa.eu/resource/authority/access-right"
                       at:table.id="access-right"
                       at:table.version.number="20260617-0">
      <skos:prefLabel xml:lang="en">Access right</skos:prefLabel>
      <owl:versionInfo>20260617-0</owl:versionInfo>
      <rdfs:label xml:lang="en">Access right</rdfs:label>
      <at:prefLabel xml:lang="en">Access right</at:prefLabel>
      <skos:hasTopConcept rdf:resource="http://publications.europa.eu/resource/authority/access-right/PUBLIC"/>
      <skos:hasTopConcept rdf:resource="http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC"/>
      <skos:hasTopConcept rdf:resource="http://publications.europa.eu/resource/authority/access-right/NORMAL"/>
      <skos:hasTopConcept rdf:resource="http://publications.europa.eu/resource/authority/access-right/OP_DATPRO"/>
   </skos:ConceptScheme>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/access-right"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/access-right"/>
      <skos:prefLabel xml:lang="en">non-public</skos:prefLabel>
      <skos:prefLabel xml:lang="pt">não público</skos:prefLabel>
      <skos:prefLabel xml:lang="mt">mhux pubbliku</skos:prefLabel>
      <skos:prefLabel xml:lang="nn">ikkje-allmenn tilgang</skos:prefLabel>
      <skos:prefLabel xml:lang="hu">nem nyilvános</skos:prefLabel>
      <skos:prefLabel xml:lang="sv">icke-offentligt</skos:prefLabel>
      <skos:prefLabel xml:lang="lt">neviešas</skos:prefLabel>
      <skos:prefLabel xml:lang="ro">neaccesibil publicului</skos:prefLabel>
      <skos:prefLabel xml:lang="it">non pubblico</skos:prefLabel>
      <skos:prefLabel xml:lang="el">μη δημόσιο</skos:prefLabel>
      <skos:prefLabel xml:lang="fr">non public</skos:prefLabel>
      <skos:prefLabel xml:lang="et">mitteavalik</skos:prefLabel>
      <skos:prefLabel xml:lang="cs">neveřejné</skos:prefLabel>
      <skos:prefLabel xml:lang="fi">ei-julkinen</skos:prefLabel>
      <skos:prefLabel xml:lang="de">nicht öffentlich</skos:prefLabel>
      <skos:prefLabel xml:lang="pl">niepubliczny</skos:prefLabel>
      <skos:prefLabel xml:lang="ga">neamhphoiblí</skos:prefLabel>
      <skos:prefLabel xml:lang="hr">nije za javnu objavu</skos:prefLabel>
      <skos:prefLabel xml:lang="nl">niet-openbaar</skos:prefLabel>
      <skos:prefLabel xml:lang="sl">nejavno</skos:prefLabel>
      <skos:prefLabel xml:lang="sk">neverejné</skos:prefLabel>
      <skos:prefLabel xml:lang="es">no público</skos:prefLabel>
      <skos:prefLabel xml:lang="lv">nav publisks</skos:prefLabel>
      <skos:prefLabel xml:lang="nb">ikke-allmenn tilgang</skos:prefLabel>
      <skos:prefLabel xml:lang="no">ikke-allmenn tilgang</skos:prefLabel>
      <skos:prefLabel xml:lang="bg">непубличен</skos:prefLabel>
      <skos:prefLabel xml:lang="da">ikke-offentlig</skos:prefLabel>
      <skos:definition xml:lang="en">access status for resources that are not publicly accessible for privacy, security or other reasons</skos:definition>
      <skos:scopeNote xml:lang="en">Non-public resources may contain personal data, but this is not a defining criterion. Information on the presence of personal data should be indicated separately.</skos:scopeNote>
      <dc:identifier>NON_PUBLIC</dc:identifier>
      <atold:op-code>NON_PUBLIC</atold:op-code>
      <at:op-code>NON_PUBLIC</at:op-code>
      <at:start.use>2013-01-01</at:start.use>
      <at:authority-code>NON_PUBLIC</at:authority-code>
      <skos:narrower rdf:resource="http://publications.europa.eu/resource/authority/access-right/CONFIDENTIAL"/>
      <skos:narrower rdf:resource="http://publications.europa.eu/resource/authority/access-right/RESTRICTED"/>
      <skos:narrower rdf:resource="http://publications.europa.eu/resource/authority/access-right/SENSITIVE"/>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/access-right/NORMAL"
